[
  {
    "context": "Pane",
    "bindings": {
      "cmd-alt-up": "workspace::ActivatePaneUp",
      "cmd-alt-down": "workspace::ActivatePaneDown",
      "cmd-alt-left": "workspace::ActivatePaneLeft",
      "cmd-alt-right": "workspace::ActivatePaneRight",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-alt-up": "workspace::ActivatePaneUp",
      "cmd-alt-down": "workspace::ActivatePaneDown",
      "cmd-alt-left": "workspace::ActivatePaneLeft",
      "cmd-alt-right": "workspace::ActivatePaneRight",
      "cmd-backspace": "editor::DeleteToPreviousWordStart",
      "cmd-delete": "editor::DeleteToNextWordEnd",
      "cmd-left": "editor::MoveToPreviousWordStart",
      "cmd-right": "editor::MoveToNextWordEnd",
      "cmd-a": "editor::MoveToBeginningOfLine",
      "cmd-e": "editor::MoveToEndOfLine",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-shift-c": "terminal::Copy",
      "cmd-shift-v": "terminal::Paste",
      "cmd-c": ["terminal::SendText", "\u0003"],
      "cmd-d": ["terminal::SendText", "\u0004"],
      "cmd-w": ["terminal::SendText", "\u0017"],
      "cmd-backspace": ["terminal::SendText", "\u0017"],
      "cmd-a": ["terminal::SendText", "\u0001"],
      "cmd-e": ["terminal::SendText", "\u0005"],
      "cmd-u": ["terminal::SendText", "\u0015"],
      "cmd-k": ["terminal::SendText", "\u000b"],
      "cmd-l": ["terminal::SendText", "\u000c"],
      "cmd-r": ["terminal::SendText", "\u0012"],
      "cmd-z": ["terminal::SendText", "\u001a"],
      "cmd-left": ["terminal::SendText", "\u001bb"],
      "cmd-right": ["terminal::SendText", "\u001bf"],
      "cmd-shift-e": "pane::SplitHorizontal",
      "cmd-shift-o": "pane::SplitVertical",
    },
  },
  {
    "context": "!ContextEditor > (Editor && mode == full)",
    "bindings": {
      "cmd-enter": "assistant::InlineAssist",
    },
  },
]
